# =============================================
# DENTORA AI - Environment Variables
# Copy this file to .env.local and fill values
# =============================================

# ---- SUPABASE ----
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- AI PROVIDERS ----
# Primary: Google Gemini (free tier: 1500 req/day)
GEMINI_API_KEY=your-gemini-api-key

# Fallback: OpenRouter (free models available)
OPENROUTER_API_KEY=your-openrouter-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# Optional: override the OpenRouter model (defaults to meta-llama/llama-3.1-8b-instruct:free)
# OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Optional: Local Ollama (self-hosted, fully free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ---- APP CONFIG ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Dentora AI

# AI Provider preference (gemini | openrouter | ollama)
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash

# ---- ANALYTICS ----
# PostHog (free tier: 1M events/month)
NEXT_PUBLIC_POSTHOG_KEY=your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ---- STORAGE ----
# Supabase Storage bucket names (created automatically)
SUPABASE_BUCKET_NOTES=dentora-notes
SUPABASE_BUCKET_PAPERS=dentora-papers
SUPABASE_BUCKET_AVATARS=dentora-avatars

# ---- SECURITY ----
NEXTAUTH_SECRET=your-secret-32-chars-minimum
CRON_SECRET=your-cron-secret

# ---- FEATURE FLAGS ----
NEXT_PUBLIC_ENABLE_VOICE=true
NEXT_PUBLIC_ENABLE_LEADERBOARD=false
NEXT_PUBLIC_ENABLE_ADMIN=true
NEXT_PUBLIC_COLLEGE_CODE=MIDS
